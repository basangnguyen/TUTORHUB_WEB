#!/bin/sh
set -eu

run_pnpm() {
  if command -v pnpm >/dev/null 2>&1; then
    pnpm "$@"
  elif command -v corepack >/dev/null 2>&1; then
    corepack pnpm "$@"
  elif command -v cmd.exe >/dev/null 2>&1; then
    cmd.exe /d /c pnpm "$@"
  else
    echo "pnpm was not found. Install pnpm 11.7.x or enable Corepack." >&2
    exit 1
  fi
}

run_pnpm format:check
run_pnpm lint
