{
  "name": "@tutorhub/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "pnpm generate:check && tsc --noEmit",
    "generate": "node scripts/generate.mjs",
    "generate:check": "node scripts/generate.mjs --check",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "prettier": "3.9.5",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "openapi-fetch": "0.17.0"
  }
}
