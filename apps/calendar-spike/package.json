{
  "name": "@tutorhub/calendar-spike",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite --host 127.0.0.1 --port 4174",
    "e2e": "vite build && playwright test --config playwright.config.ts",
    "lint": "eslint src e2e vite.config.ts playwright.config.ts",
    "security:dependencies": "node scripts/check-dependencies.mjs",
    "test": "vitest run",
    "test:guard": "node --test scripts/check-dependencies.test.mjs",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.e2e.json --pretty false"
  },
  "dependencies": {
    "@fullcalendar/react": "7.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "temporal-polyfill": "1.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.10.13",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
