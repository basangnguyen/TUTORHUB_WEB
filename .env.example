APP_ENV=development
PORT=8080
# Optional IP literal; leave empty to keep the default all-interface bind.
HTTP_LISTEN_HOST=
PUBLIC_WEB_ORIGIN=http://localhost:5173
PUBLIC_API_ORIGIN=http://localhost:8080
LOG_LEVEL=info
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
HTTP_MAX_HEADER_BYTES=1048576
VITE_API_BASE_URL=/api

# Shared base64/base64url key (32+ decoded bytes) used to authenticate Cloudflare
# edge client-prefix context. Required in staging/production and must match the
# EDGE_CONTEXT_SECRET configured for the Pages Function.
EDGE_CONTEXT_SECRET=
EDGE_CONTEXT_MAX_SKEW=2m

# Deployment guardrails. They can only disable features or lower tenant limits.
FEATURE_CONTROL_DISABLE_MEMBERSHIP_INVITATIONS=false
FEATURE_CONTROL_DISABLE_CLASS_MANAGEMENT=false
FEATURE_CONTROL_DISABLE_CLASS_INVITE_LINKS=false
FEATURE_CONTROL_MAX_MEMBERS=10000
FEATURE_CONTROL_MAX_ACTIVE_CLASSES=1000
FEATURE_CONTROL_MAX_INVITE_CREATIONS_PER_HOUR=10000

# Local-only credentials used by compose.yaml. Never reuse these values outside development.
# With Neon, replace DATABASE_POOL_URL with the pooled URL whose host contains -pooler.
DATABASE_POOL_URL=postgresql://tutorhub:tutorhub_local@localhost:5432/tutorhub?sslmode=disable
# Direct URL for local migration jobs only. Never expose a production migration URL to the API.
DATABASE_MIGRATION_URL=postgresql://tutorhub:tutorhub_local@localhost:5432/tutorhub?sslmode=disable
REDIS_URL=redis://localhost:6379/0
DATABASE_MAX_CONNECTIONS=4
DATABASE_MIN_CONNECTIONS=0
DATABASE_CONNECT_TIMEOUT=10s
DATABASE_QUERY_TIMEOUT=5s
DATABASE_MAX_CONNECTION_LIFETIME=30m
DATABASE_MAX_CONNECTION_IDLE_TIME=5m
DATABASE_HEALTH_CHECK_PERIOD=1m
SESSION_SECRET=
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:8080/api/v1/auth/callback
OIDC_POST_LOGOUT_URL=http://localhost:5173/signed-out
OIDC_SCOPES=openid profile email
AUTH_FLOW_TTL=10m
SESSION_TTL=8h
SESSION_ABSOLUTE_TTL=24h
MEMBERSHIP_INVITATION_TTL=168h
SESSION_COOKIE_SECURE=false
B2_ENDPOINT=
B2_REGION=
B2_BUCKET=
B2_KEY_ID=
B2_APPLICATION_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL=5m
