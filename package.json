{
  "name": "tutorhub-v2",
  "version": "0.0.0",
  "private": true,
  "description": "TutorHub V2 web-first learning ecosystem",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.14.0 <25",
    "pnpm": "11.7.x"
  },
  "scripts": {
    "api:generate": "pnpm --filter @tutorhub/api-client generate",
    "api:check": "pnpm --filter @tutorhub/api-client generate:check",
    "db:migrate": "go run ./services/core-api/cmd/migrate up",
    "db:seed": "go run ./services/core-api/cmd/seed",
    "db:version": "go run ./services/core-api/cmd/migrate version",
    "dev": "turbo run dev --parallel",
    "dev:local": "node scripts/local-dev.mjs dev",
    "e2e": "playwright test",
    "e2e:infra:test": "node --test scripts/e2e-local.test.mjs",
    "e2e:install": "playwright install chromium",
    "e2e:typecheck": "tsc -p tsconfig.e2e.json --pretty false",
    "local:setup": "node scripts/local-dev.mjs setup",
    "local:status": "node scripts/local-dev.mjs status",
    "local:down": "node scripts/local-dev.mjs down",
    "local:reset": "node scripts/local-dev.mjs reset",
    "local:test": "node --test scripts/local-dev.test.mjs",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "build": "turbo run build",
    "lint": "eslint eslint.config.mjs scripts e2e playwright.config.ts .storybook && turbo run lint",
    "typecheck": "turbo run typecheck && pnpm e2e:typecheck",
    "test": "turbo run test",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build --output-dir storybook-static",
    "test:integration": "go test -count=1 -tags=integration ./services/core-api/internal/platform/migrationrunner && go test -count=1 -tags=integration ./services/core-api/internal/modules/classroom && go test -count=1 -tags=integration ./services/core-api/internal/modules/identity && go test -count=1 -tags=integration ./services/core-api/internal/modules/audit && go test -count=1 -tags=integration ./services/core-api/internal/modules/featurecontrol",
    "security:actions": "node scripts/check-github-actions-security.mjs",
    "security:bundle": "node scripts/check-client-bundle-security.mjs",
    "security:test": "node --test scripts/check-github-actions-security.test.mjs scripts/check-client-bundle-security.test.mjs scripts/edge-context.test.mjs",
    "format": "prettier --write \"apps/**/*.{ts,tsx,css,html,json}\" \"packages/**/*.{ts,tsx,css,json}\" \"scripts/**/*.{js,mjs,ts}\" \"e2e/**/*.{ts,tsx,json}\" \".storybook/**/*.{ts,tsx,css}\" \"*.{json,yaml,yml,mjs,ts}\" \".github/**/*.{yaml,yml}\" \"openapi/**/*.{yaml,yml}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,css,html,json}\" \"packages/**/*.{ts,tsx,css,json}\" \"scripts/**/*.{js,mjs,ts}\" \"e2e/**/*.{ts,tsx,json}\" \".storybook/**/*.{ts,tsx,css}\" \"*.{json,yaml,yml,mjs,ts}\" \".github/**/*.{yaml,yml}\" \"openapi/**/*.{yaml,yml}\"",
    "verify:web": "pnpm lint && pnpm typecheck && turbo run test build && pnpm storybook:build && pnpm security:bundle",
    "verify:go": "go test ./services/core-api/... && go vet ./services/core-api/...",
    "verify": "pnpm format:check && pnpm api:check && pnpm local:test && pnpm e2e:infra:test && pnpm security:test && pnpm security:actions && pnpm verify:web && pnpm verify:go"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "10.5.0",
    "@storybook/addon-docs": "10.5.0",
    "@storybook/react-vite": "10.5.0",
    "@types/node": "24.10.13",
    "eslint": "10.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "storybook": "10.5.0",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0"
  }
}
